# Governed RAG environment variables.
#
# Copy this file to .env and fill in values for the live self-host path. Tests,
# CI, and the read-only demo never need any of these: they run on fixtures,
# recorded cassettes, and committed judge verdicts. Keys are only for live
# ingest (embedding real filings), live generation, and cassette recording.
#
# Every variable the code reads must be documented here as it is introduced.

# --- Generation (Anthropic) ---
# Required for live query/generation and for recording AgentProbe cassettes.
# Never required to run tests or replay.
ANTHROPIC_API_KEY=

# --- Embeddings (Voyage AI) ---
# Required for live ingest embedding. Tests use a deterministic local embedder
# behind the same interface, so this is empty in CI.
VOYAGE_API_KEY=

# --- Query API auth ---
# Single-tenant bearer token guarding the query API (v1 access control).
# Generate a random value for self-host. Leave empty to disable the guard in
# local development only.
QUERY_API_BEARER_TOKEN=

# --- Observability (OpenTelemetry) ---
# OTLP/HTTP endpoint for traces. If unset, tracing is a no-op and the pipeline
# runs normally. Point this at any OTLP collector (Overseer for Agents included).
OTEL_EXPORTER_OTLP_ENDPOINT=
# Optional service name override for emitted traces.
OTEL_SERVICE_NAME=governed-rag

# --- EDGAR ingest (fair-access compliance) ---
# SEC requires a declared User-Agent identifying the requester. Set this before
# any live EDGAR fetch. CI never fetches from EDGAR.
EDGAR_USER_AGENT=
