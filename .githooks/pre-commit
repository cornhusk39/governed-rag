#!/usr/bin/env bash
# Secret-scanning gate. Runs gitleaks against staged changes before every commit.
# A finding aborts the commit. This is intentionally strict: a leaked secret in
# history is far more expensive to remove than a blocked commit is to fix.
set -euo pipefail

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-commit: gitleaks is not installed." >&2
  echo "Install it (brew install gitleaks) so the secret gate can run." >&2
  exit 1
fi

# gitleaks 8.30 replaced the old "protect" command with "git --staged", which
# scans exactly what is about to be committed. --redact keeps any finding out of
# the terminal log so a real secret is not echoed while still alerting.
gitleaks git --staged --redact --no-banner --config .gitleaks.toml
