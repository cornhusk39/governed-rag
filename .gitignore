# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Guard against accidentally committing compiled output next to source. Builds
# always emit to dist/; nothing compiled belongs under a package src/.
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# Next.js
.next/
out/
packages/web/.next/
packages/web/out/

# SQLite databases and index artifacts. These are generated by ingest and the
# audit log. They can hold corpus text and query history, so they never belong
# in git. Seeded demo data, if any, is committed explicitly by path.
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
# Root-level generated data and index dirs (CLI default db lives here). Anchored
# so committed fixtures like packages/web/data/ are not swept up; the *.db and
# *.sqlite globs above still catch stray database files anywhere.
/data/
/index/

# Secrets. Only the example file is tracked.
.env
.env.*
!.env.example

# Test and tooling output
coverage/
.vitest/

# OS and editor noise
.DS_Store
*.log

# Local tooling/editor scratch (kept out of the published repo)
.claude/
